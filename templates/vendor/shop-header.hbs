<header class="sheet-header">
  <div class="portrait">
    <div class="pus-portrait-clip">
      <img class="document-image" src="{{actor.img}}" alt="{{actor.name}}" />
    </div>
  </div>
  <div class="header-details">
    <div class="document-name">{{actor.name}}</div>
    {{#if publicBio}}
    <div class="vendor-description">{{{publicBio}}}</div>
    {{/if}}
  </div>
</header>
